{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "NGK",
	"scopeName": "source.ngk",
	"patterns": [
		{ "include": "#comments" },
		{ "include": "#section-headers" },
		{ "include": "#commands" },
		{ "include": "#group-block" },
		{ "include": "#loop-block" },
		{ "include": "#particle-types" },
		{ "include": "#modifiers" },
		{ "include": "#strings" },
		{ "include": "#numbers" }
	],
	"repository": {
		"comments": {
			"match": "#.*$",
			"name": "comment.line.number-sign.ngk"
		},
		"section-headers": {
			"match": "^\\s*\\[(Options|Preload|Commands|Hotkeys|RevyData|Structure|Display|Particle\\.[A-Z]+)\\]\\s*$",
			"captures": {
				"1": { "name": "entity.name.section.ngk" }
			},
			"name": "meta.section.ngk"
		},
		"commands": {
			"match": "(?<![A-Za-z0-9_])(text|textCont|textbf|textit|textbfCont|textitCont|textD|clear|clearText|clearImages|clearAll|play|stop|stopParticleCont|show|comment)(?![A-Za-z0-9_])",
			"name": "keyword.control.ngk"
		},
		"group-block": {
			"match": "(?<![A-Za-z0-9_])(group)\\s+([A-Za-z_][A-Za-z0-9_]*)",
			"captures": {
				"1": { "name": "keyword.control.group.ngk" },
				"2": { "name": "entity.name.tag.group.ngk" }
			}
		},
		"loop-block": {
			"match": "(?<![A-Za-z0-9_])(loop)\\s*\\(",
			"captures": {
				"1": { "name": "keyword.control.loop.ngk" }
			}
		},
		"particle-types": {
			"match": "(?<![A-Za-z0-9_])(RAIN|SNOW|CONFETTI|RISE|SCATTER|BROWNIAN|OSCILLATION|ORBIT|NOISE|LIFECURVE|GHOST|STRETCH|GLOW|UNIFORM|NORMAL|LOGNORMAL|BINOMIAL|BERNOULLI|GAMMA)(?![A-Za-z0-9_])",
			"name": "constant.language.particle.ngk"
		},
		"modifiers": {
			"match": "(?<![A-Za-z0-9_])(color|trans|rotate|move|spin|pos|size|particle|randomImages|randomSize|bold|it|trail|trailGlow|bounce)(?=\\s*\\()",
			"name": "support.function.modifier.ngk"
		},
		"strings": {
			"name": "string.quoted.double.ngk",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.ngk",
					"match": "\\\\."
				}
			]
		},
		"numbers": {
			"match": "(?<![A-Za-z0-9_])-?[0-9]+(\\.[0-9]+)?(?![A-Za-z0-9_])",
			"name": "constant.numeric.ngk"
		}
	}
}
